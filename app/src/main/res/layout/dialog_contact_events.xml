<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Информация о контакте -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvContactName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/tvContactPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autoLink="phone"
            android:ellipsize="end"
            android:maxLines="1"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Кнопка добавления события -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_event"
        android:layout_marginBottom="16dp" />

    <!-- Счетчики событий в виде чипсов -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/event_stats_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:chipSpacing="8dp"
        app:singleLine="false">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNew"
            style="@style/Widget.MaterialComponents.Chip.Entry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:text="@string/event_stats_meetings_0"
            app:chipBackgroundColor="@color/event_chip_meetings"
            app:chipIconVisible="false"
            app:closeIconVisible="false"
            android:textColor="@android:color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipInProgress"
            style="@style/Widget.MaterialComponents.Chip.Entry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:text="@string/event_stats_calls_0"
            app:chipBackgroundColor="@color/event_chip_calls"
            app:chipIconVisible="false"
            app:closeIconVisible="false"
            android:textColor="@android:color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipNegotiation"
            style="@style/Widget.MaterialComponents.Chip.Entry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:text="@string/event_stats_other_0"
            app:chipBackgroundColor="@color/event_chip_other"
            app:chipIconVisible="false"
            app:closeIconVisible="false"
            android:textColor="@android:color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipConverted"
            style="@style/Widget.MaterialComponents.Chip.Entry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            app:chipBackgroundColor="@color/event_chip_extra"
            app:chipIconVisible="false"
            app:closeIconVisible="false"
            android:textColor="@android:color/white"
            android:visibility="gone" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipLost"
            style="@style/Widget.MaterialComponents.Chip.Entry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:text="@string/event_stats_total_0"
            app:chipBackgroundColor="@color/event_chip_total"
            app:chipIconVisible="false"
            app:closeIconVisible="false"
            android:textColor="@android:color/white" />

    </com.google.android.material.chip.ChipGroup>

    <!-- Блок "Последние события" полностью удален -->
    <!-- Удалены RecyclerView и TextView для списка событий -->

</LinearLayout>