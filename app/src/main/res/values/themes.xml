<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ContactManager" parent="Theme.Material3.DayNight">
        <!-- Telegram-like accent -->
        <item name="colorPrimary">@color/tg_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/tg_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surfaces / background -->
        <item name="android:windowBackground">@color/tg_bg</item>
        <item name="colorSurface">@color/tg_surface</item>
        <item name="colorOnSurface">@color/tg_on_surface</item>
        <item name="colorSurfaceVariant">@color/tg_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/tg_on_surface_variant</item>

        <!-- For AppCompat widgets (CheckBox/Switch, etc.) -->
        <item name="colorControlActivated">@color/tg_blue</item>
        <item name="colorControlHighlight">@color/tg_blue</item>
        <item name="colorError">@android:color/holo_red_dark</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/tg_bg</item>
        <item name="android:navigationBarColor">@color/tg_bg</item>

        <!-- Typography (readable default) -->
        <item name="android:fontFamily">sans-serif</item>

        <!-- Widget defaults -->
        <item name="materialButtonStyle">@style/Widget.ContactManager.Button</item>
        <item name="checkboxStyle">@style/Widget.ContactManager.CheckBox</item>
        <item name="switchStyle">@style/Widget.ContactManager.Switch</item>
        <item name="bottomNavigationStyle">@style/Widget.ContactManager.BottomNavigation</item>
    </style>
</resources>